<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Feener.Pages.CollectFriendsPage"
             Title="Collect Friends"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ─── Header ─── -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                Stroke="Transparent"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="20">
            <VerticalStackLayout Spacing="4">
                <Label Text="Collect Friends"
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"
                       FontFamily="InterSemiBold"
                       FontSize="20"/>
                <Label x:Name="SubtitleLabel"
                       Text="Import friends directly from your TikTok DMs"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"
                       FontSize="13"
                       LineBreakMode="WordWrap"/>
            </VerticalStackLayout>
        </Border>

        <!-- ─── WebView ─── -->
        <WebView x:Name="TikTokWebView"
                 Grid.Row="1"
                 Navigated="OnWebViewNavigated"/>

        <!-- ─── Loading Overlay ─── -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="1"
              IsVisible="True"
              BackgroundColor="{AppThemeBinding Light={StaticResource OverlayLight}, Dark={StaticResource OverlayDark}}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"
                                   HeightRequest="48"
                                   WidthRequest="48"/>
                <Label x:Name="LoadingLabel"
                       Text="Loading TikTok Messages..."
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ─── Collection Status Overlay (semi-transparent — WebView stays visible) ─── -->
        <Grid x:Name="CollectingOverlay"
              Grid.Row="1"
              IsVisible="False"
              BackgroundColor="{AppThemeBinding Light=#B0FFFFFF, Dark=#B0000000}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Padding="32">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource White}}"
                                   HeightRequest="48"
                                   WidthRequest="48"/>
                <Label x:Name="CollectingStatusLabel"
                       Text="Collecting friends..."
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray200}}"
                       FontFamily="InterSemiBold"
                       FontSize="16"
                       HorizontalOptions="Center"/>
                <Label x:Name="CollectingCountLabel"
                       Text="0 found so far"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ─── Results Overlay ─── -->
        <Grid x:Name="ResultsOverlay"
              Grid.Row="1"
              IsVisible="False"
              BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource OffBlack}}">
            <ScrollView Padding="20">
                <VerticalStackLayout Spacing="16">

                    <!-- Summary Card -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="12">
                            <Label x:Name="ResultsTitleLabel"
                                   Text="Collection Complete"
                                   FontFamily="InterSemiBold"
                                   FontSize="18"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource White}}"/>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="ResultsTotalLabel" Text="0"
                                           Style="{StaticResource ValueLabel}" HorizontalTextAlignment="Center"/>
                                    <Label Text="Found" Style="{StaticResource DataLabel}" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="ResultsNewLabel" Text="0"
                                           Style="{StaticResource ValueLabel}" HorizontalTextAlignment="Center"/>
                                    <Label Text="New" Style="{StaticResource DataLabel}" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="ResultsExistingLabel" Text="0"
                                           Style="{StaticResource ValueLabel}" HorizontalTextAlignment="Center"/>
                                    <Label Text="Already Added" Style="{StaticResource DataLabel}" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Friends List Preview -->
                    <Border Style="{StaticResource SectionCard}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Friends Found" Style="{StaticResource SectionLabel}"/>
                            <VerticalStackLayout x:Name="ResultsListContainer" Spacing="6"/>
                            <Label x:Name="NoResultsLabel"
                                   Text="No new friends found."
                                   Style="{StaticResource DataLabel}"
                                   HorizontalOptions="Center"
                                   IsVisible="False"/>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ─── Footer Actions ─── -->
        <Border Grid.Row="2" Style="{StaticResource BottomActionBorder}">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Button x:Name="BackButton"
                        Text="Back"
                        Style="{StaticResource TextButton}"
                        HeightRequest="44"
                        Clicked="OnBackClicked"/>
                <Button x:Name="ActionButton"
                        Grid.Column="1"
                        Text="Waiting..."
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}"
                        FontFamily="InterSemiBold"
                        CornerRadius="14"
                        HeightRequest="44"
                        IsEnabled="False"
                        Clicked="OnActionClicked"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
